# Byte-compiled / optimized / DLL files
__pycache__/
*.py[cod]
*$py.class

# Environment
.env
.venv/
venv/
env/

# Distribution / packaging
*.egg-info/
*.egg
dist/
build/

# Data
data/raw/*
data/processed/*
data/external/*

# Keep gitkeep files
!data/raw/.gitkeep
!data/processed/.gitkeep
!data/external/.gitkeep

# Cache
data/.cache/
.cache/

# Logs
logs/*.log
!logs/.gitkeep

# IDE
.vscode/
.idea/
*.swp
*.swo

# OS
Thumbs.db
.DS_Store

# Jupyter
.ipynb_checkpoints/

# Reports (generated figures)
reports/figures/

# ──────────────────────────────────────────────────────────────
# AOT Stock Network — Environment Variables
# ──────────────────────────────────────────────────────────────
# Copy this file to .env and fill in your credentials.

# SET OAQ API Key (required for automated stock data fetching)
# Obtain from: https://www.set.or.th/app/online-data/developer-guide/generate-api-key
# Registration is free; the API key enables OAQ (Online Asset Quotation) access.
SET_API_KEY=

# Data directory (optional, defaults to ./data)
# AOT_DATA_DIR=./data

# Log level (DEBUG, INFO, WARNING, ERROR)
# AOT_LOG_LEVEL=INFO
